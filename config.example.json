{
  "_comment": "Copy this file to config.json and fill in your values. Never commit config.json.",
  "hosts": {
    "example-host": {
      "hostname": "192.168.1.100",
      "port": 22,
      "username": "your-user",
      "key_path": "~/.ssh/id_ed25519"
    },
    "example-remote": {
      "hostname": "10.0.0.5",
      "port": 22,
      "username": "deploy",
      "key_path": "~/.ssh/deploy_key",
      "known_hosts": "~/.ssh/known_hosts"
    }
  },
  "default_timeout": 30,
  "max_parallel_hosts": 10,
  "log_level": "INFO"
}
